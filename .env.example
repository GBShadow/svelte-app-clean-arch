# PocketBase — superusuário do painel /_/
PB_ADMIN_EMAIL=admin@example.com
PB_ADMIN_PASSWORD=changeme123456

# PocketBase — conta de aplicação semeada (auth + user)
SEED_ADMIN_EMAIL=seed-admin@example.com
SEED_ADMIN_PASSWORD=changeme123456

# URL pública do PocketBase, consumida pelos apps SvelteKit
PUBLIC_POCKETBASE_URL=http://127.0.0.1:8090

# Web Push (VAPID) — gere o par real com `npx web-push generate-vapid-keys`.
# PUBLIC_VAPID_PUBLIC_KEY é exposta ao browser (usada em pushManager.subscribe);
# VAPID_PRIVATE_KEY nunca deve ser exposta ao client.
PUBLIC_VAPID_PUBLIC_KEY=BExampleVapidPublicKeyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
VAPID_PRIVATE_KEY=ExampleVapidPrivateKeyXXXXXXXXXXXXXXXXXXXX
VAPID_SUBJECT=mailto:admin@example.com
