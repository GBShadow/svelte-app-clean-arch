		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.2",
		"@testing-library/svelte": "^5.3.1",
		"@vitest/browser-playwright": "^4.1.8",
		"daisyui": "^5.6.16",
		"happy-dom": "^20.10.6",
		"playwright": "^1.60.0",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"tailwindcss": "^4.3.2",
		"typescript": "^6.0.3",
