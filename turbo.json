{
	"$schema": "https://turbo.build/schema.json",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": [".svelte-kit/**", "build/**", "dist/**"]
		},
		"test": {
			"dependsOn": ["^test"],
			"outputs": []
		},
		"check": {
			"dependsOn": ["^check"],
			"outputs": []
		},
		"dev": {
			"cache": false,
			"persistent": true
		},
		"prepare": {
			"cache": false
		}
	}
}
