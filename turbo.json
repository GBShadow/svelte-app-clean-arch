{
	"$schema": "https://turbo.build/schema.json",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": [".svelte-kit/**", "build/**", "dist/**"]
		},
		"test": {
			"dependsOn": ["^test"],
			"outputs": []
		},
		"test:coverage": {
			"dependsOn": ["^test:coverage"],
			"outputs": ["coverage/**"]
		},
		"test:e2e": {
			"outputs": ["playwright-report/**", "test-results/**"]
		},
		"check": {
			"dependsOn": ["^check"],
			"outputs": []
		},
		"dev": {
			"cache": false,
			"persistent": true
		},
		"backend:dev": {
			"cache": false,
			"persistent": true
		},
		"backend:down": {
			"cache": false
		},
		"backend:reset": {
			"cache": false
		},
		"dev:full": {
			"cache": false,
			"persistent": true
		},
		"dev:reset": {
			"cache": false,
			"persistent": true
		},
		"prepare": {
			"cache": false
		}
	}
}
